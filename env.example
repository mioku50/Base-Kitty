# App URL (must match your deployment domain)
NEXT_PUBLIC_URL=https://base-kitty.vercel.app

# Farcaster Mini App manifest — accountAssociation
# Generate these by signing your domain with your Farcaster custody address
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=

# Neynar API key (for user profile enrichment and social features)
# Get one at https://neynar.com
NEYNAR_API_KEY=
