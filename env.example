# App URL (must match your deployment domain)
NEXT_PUBLIC_URL=https://base-kitty.vercel.app

# Farcaster Mini App manifest — accountAssociation
# Generate these by signing your domain with your Farcaster custody address
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=

# Neynar API key + client id (for user profile enrichment, social features and Neynar webhook mode)
# Get one at https://neynar.com
NEYNAR_API_KEY=
NEYNAR_CLIENT_ID=

# Upstash Redis REST API (required in production unless KV is explicitly disabled)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Explicit local/dev mode flag for notification token storage.
# true  -> disable Redis and use in-memory storage (non-persistent)
# false -> require KV_REST_API_URL + KV_REST_API_TOKEN
DISABLE_KV=false
