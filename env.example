# Production required: canonical app URL (no trailing slash)
# Preview: optional, host header fallback is used by auth verification
NEXT_PUBLIC_URL=https://base-kitty.vercel.app

# Production required for signed Mini App manifest accountAssociation
# Preview/dev may be left empty
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=

# Required for social profile enrichment and webhook app-key verification
NEYNAR_API_KEY=

# Optional: only needed for Neynar-hosted notification webhook workflows
NEYNAR_CLIENT_ID=

# Strongly recommended in production: persistent leaderboard storage.
# If empty, scores are kept only in memory and can reset between deploys/instances.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Alternative Vercel KV aliases (same value pair)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional: recipient for the "gm on Base" onchain action (0x...)
# If empty, tx is sent to the user's own address with calldata "gm".
NEXT_PUBLIC_GM_TARGET_ADDRESS=
